---
import Layout from '../layouts/Layout.astro';
import toolsData from '../data/tools.json';
import pageContent from '../data/page-content.json';

const { 'which-ai-tool': pc } = pageContent as any;
const tools = toolsData as any[];

const quizData = {
  questions: pc.questions || [],
  allTools: tools,
  reasons: pc.matching_reasons || {},
  copy: {
    results_title: pc.results_title,
    results_cta: pc.results_cta,
    results_feature_bullet: pc.results_feature_bullet,
    no_results_title: pc.no_results_title,
    no_results_description: pc.no_results_description,
    no_results_browse: pc.no_results_browse,
    restart_button: pc.restart_button,
    default_reason: (pc.matching_reasons || {}).default_recommendation_reason || 'Based on your preferences, this tool offers the best balance of features, price, and ease of use.',
  },
};
---

<Layout title={pc.seo_title.split(' — ')[0]} description={pc.seo_description}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-16">
    <div class="text-center mb-12">
      <h1 class="text-3xl md:text-4xl font-extrabold text-on-surface mb-4">{pc.hero_title}</h1>
      <p class="text-base md:text-lg text-on-surface-variant max-w-2xl mx-auto leading-relaxed">{pc.hero_subtitle}</p>
    </div>

    <div id="quiz-container">
      <div id="quiz-start" class="text-center">
        <p class="text-on-surface-variant mb-8 leading-relaxed">{pc.quiz_description}</p>
        <button
          id="start-btn"
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-primary text-white font-semibold rounded-xl hover:bg-primary-hover transition-colors shadow-sm"
        >
          Start Quiz
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </button>
      </div>

      <div id="quiz-questions" class="hidden">
        <div class="mb-6">
          <div id="progress-bar" class="w-full h-2 bg-gray-200 rounded-full overflow-hidden">
            <div id="progress-fill" class="h-full bg-primary rounded-full transition-all duration-300" style="width: 0%"></div>
          </div>
          <p id="progress-text" class="text-xs text-on-surface-variant mt-2 text-right">Question 1 of 3</p>
        </div>

        <div id="question-content" class="bg-surface border border-outline-variant/40 rounded-xl p-8 md:p-10 mb-6">
          <h2 id="question-title" class="text-xl md:text-2xl font-bold text-on-surface mb-2"></h2>
          <p id="question-desc" class="text-sm text-on-surface-variant mb-8"></p>
          <div id="options-container" class="space-y-3"></div>
        </div>
      </div>

      <div id="quiz-results" class="hidden">
        <div class="text-center mb-10">
          <h2 class="text-2xl md:text-3xl font-bold text-on-surface mb-3">{pc.results_title}</h2>
          <p class="text-on-surface-variant">{pc.results_subtitle}</p>
        </div>
        <div id="result-cards" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10"></div>
        <div class="text-center">
          <button
            onclick="restartQuiz()"
            class="inline-flex items-center gap-2 px-6 py-3 bg-surface border border-outline-variant/40 text-on-surface font-semibold rounded-xl hover:border-primary/30 hover:text-primary transition-all"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            {pc.restart_button}
          </button>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script type="text/javascript" set:html={`const QUIZ = ${JSON.stringify(quizData)};
const { questions, allTools, reasons, copy } = QUIZ;

let currentStep = 0;
let answers = {};

function startQuiz() {
  document.getElementById('quiz-start').classList.add('hidden');
  document.getElementById('quiz-questions').classList.remove('hidden');
  currentStep = 0;
  answers = {};
  showQuestion();
}

function showQuestion() {
  const q = questions[currentStep];
  document.getElementById('question-title').textContent = q.question;
  document.getElementById('question-desc').textContent = q.description;
  document.getElementById('progress-text').textContent = 'Question ' + (currentStep + 1) + ' of ' + questions.length;
  const pct = (currentStep / questions.length) * 100;
  document.getElementById('progress-fill').style.width = pct + '%';

  const container = document.getElementById('options-container');
  container.innerHTML = '';
  q.options.forEach(function(opt) {
    const btn = document.createElement('button');
    btn.className = 'w-full text-left p-4 rounded-xl border border-outline-variant/40 hover:border-primary/40 hover:bg-primary/5 transition-all group';
    btn.innerHTML = '<span class=\"block text-sm font-semibold text-on-surface group-hover:text-primary transition-colors\">' + opt.label + '</span><span class=\"block text-xs text-on-surface-variant mt-1\">' + opt.description + '</span>';
    btn.onclick = function() { selectOption(q.id, opt.value); };
    container.appendChild(btn);
  });
}

function selectOption(qid, value) {
  answers[qid] = value;
  currentStep++;
  const pct = (currentStep / questions.length) * 100;
  document.getElementById('progress-fill').style.width = pct + '%';
  if (currentStep >= questions.length) {
    showResults();
  } else {
    showQuestion();
  }
}

function showResults() {
  document.getElementById('quiz-questions').classList.add('hidden');
  document.getElementById('quiz-results').classList.remove('hidden');

  const useCase = answers['use_case'] || 'writing';
  const budget = answers['budget'] || 'free';
  const skill = answers['skill_level'] || 'beginner';

  const catMap = {
    writing: 'AI Writing', coding: 'AI Coding', design: 'AI Image',
    video: 'AI Video', research: 'AI Research', productivity: 'AI Productivity',
  };

  const targetCat = catMap[useCase] || 'AI Writing';
  let candidates = allTools.filter(function(t) { return t.category === targetCat; });

  if (candidates.length === 0) {
    candidates = allTools.filter(function(t) {
      return ['AI Chat', 'AI Writing', 'AI Productivity'].indexOf(t.category) !== -1;
    });
  }

  if (budget === 'free') {
    var freeOnes = candidates.filter(function(t) { return t.pricing === 'Free' || t.pricing === 'Freemium'; });
    if (freeOnes.length >= 2) candidates = freeOnes;
  } else if (budget === 'budget') {
    candidates = candidates.sort(function(a, b) {
      var aAffordable = ['Free', 'Freemium'].indexOf(a.pricing) !== -1 ? 0 : 1;
      var bAffordable = ['Free', 'Freemium'].indexOf(b.pricing) !== -1 ? 0 : 1;
      return aAffordable - bAffordable || b.rating - a.rating;
    });
  } else if (budget === 'enterprise') {
    candidates = candidates.sort(function(a, b) { return b.rating - a.rating; });
  }

  if (skill === 'beginner') {
    candidates = candidates.sort(function(a, b) {
      var aEasy = ['Free', 'Freemium'].indexOf(a.pricing) !== -1 ? 0 : 1;
      var bEasy = ['Free', 'Freemium'].indexOf(b.pricing) !== -1 ? 0 : 1;
      return aEasy - bEasy || b.rating - a.rating;
    });
  } else if (skill === 'advanced') {
    candidates = candidates.sort(function(a, b) { return b.rating - a.rating; });
  }

  var top3 = candidates.slice(0, 3);
  var reasonKey = useCase + '_' + budget + '_' + skill;
  var reasonText = reasons[reasonKey] || copy.default_reason;

  var container = document.getElementById('result-cards');
  container.innerHTML = '';

  if (top3.length === 0) {
    container.innerHTML = '<div class=\"col-span-full text-center py-12\"><p class=\"text-lg font-semibold text-on-surface mb-2\">' + copy.no_results_title + '</p><p class=\"text-sm text-on-surface-variant mb-6\">' + copy.no_results_description + '</p><a href=\"/tools\" class=\"inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-semibold rounded-xl hover:bg-primary-hover transition-colors\">' + copy.no_results_browse + '</a></div>';
    return;
  }

  top3.forEach(function(tool, idx) {
    var stars = Math.round(tool.rating);
    var starsHtml = '';
    for (var i = 0; i < 5; i++) {
      starsHtml += '<svg class=\"w-3.5 h-3.5 ' + (i < stars ? 'text-amber-400' : 'text-gray-200') + '\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path d=\"M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z\"/></svg>';
    }

    var pricingLabel = tool.pricing === 'Freemium' ? 'Freemium' : tool.pricing === 'Free' ? 'Free' : tool.pricing === 'Free Trial' ? 'Free Trial' : 'Paid';
    var topMatchBadge = idx === 0 ? '<span class=\"inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-[#eaddff] text-[#5a00c6] text-xs font-semibold self-start mb-3\">Top Match</span>' : '';

    container.innerHTML += '<div class=\"bg-surface border border-outline-variant/60 rounded-xl p-6 flex flex-col\">' + topMatchBadge + '<div class=\"flex items-center gap-3 mb-3\"><div class=\"w-10 h-10 rounded-lg bg-gradient-to-br from-primary/10 to-primary/5 flex items-center justify-center text-primary font-bold text-sm shrink-0\">' + tool.name.charAt(0) + '</div><div><h3 class=\"text-base font-bold text-on-surface\">' + tool.name + '</h3><div class=\"flex items-center gap-1\">' + starsHtml + '<span class=\"text-xs text-on-surface-variant ml-1\">' + tool.rating + '</span></div></div></div><p class=\"text-xs text-on-surface-variant mb-1 font-semibold\">' + copy.results_feature_bullet + ' ' + reasonText + '</p><p class=\"text-sm text-on-surface-variant leading-relaxed mb-4 text-truncate-3 flex-1\">' + tool.description_short + '</p><div class=\"flex items-center justify-between\"><span class=\"text-xs font-medium text-on-surface-variant\">' + pricingLabel + '</span><a href=\"/tools/' + tool.slug + '\" class=\"text-sm font-semibold text-primary hover:text-primary-hover transition-colors\">' + copy.results_cta + ' &rarr;</a></div></div>';
  });
}

function restartQuiz() {
  document.getElementById('quiz-results').classList.add('hidden');
  document.getElementById('quiz-start').classList.remove('hidden');
  currentStep = 0;
  answers = {};
}

document.getElementById('start-btn').addEventListener('click', startQuiz);`}></script>
