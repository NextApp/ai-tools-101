---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const tagMap = new Map<string, number>();

for (const post of posts) {
  for (const tag of post.data.tags) {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  }
}

const tags = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);
---

<Layout title="Tags" description="Browse AI tool tutorials and guides by topic">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <h1 class="text-3xl md:text-4xl font-extrabold text-on-surface mb-2">Tags</h1>
    <p class="text-on-surface-variant mb-8">Browse articles by topic</p>

    <div class="flex flex-wrap gap-3">
      {tags.map(([tag, count]) => (
        <a
          href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`}
          class="inline-flex items-center gap-2 px-4 py-2 bg-surface border border-outline-variant/60 rounded-full text-sm font-medium text-on-surface-variant hover:border-primary hover:text-primary transition-all shadow-sm"
        >
          {tag}
          <span class="bg-surface-bg text-on-surface-variant text-xs px-2 py-0.5 rounded-full">{count}</span>
        </a>
      ))}
    </div>

    {tags.length === 0 && (
      <p class="text-center text-on-surface-variant py-12">No tags yet.</p>
    )}
  </section>
</Layout>
