---
import Layout from '../layouts/Layout.astro';
import { socialUrl } from '../lib/social';
---

<Layout title="Contact" description="Get in touch with AI Tool Guide">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <h1 class="text-3xl md:text-4xl font-extrabold text-on-surface mb-6">Contact Us</h1>

    <p class="text-lg text-on-surface-variant mb-8">
      Have questions, suggestions, or feedback? We'd love to hear from you. Fill out the form below and we'll get back to you as soon as possible.
    </p>

    <form class="bg-surface rounded-xl border border-outline-variant/60 p-6 md:p-8 space-y-6 shadow-sm">
      <div>
        <label for="name" class="block text-sm font-medium text-on-surface mb-1">Name</label>
        <input type="text" id="name" name="name" required
          class="w-full px-4 py-2.5 bg-surface-bg border border-outline-variant rounded-lg text-sm text-on-surface placeholder:text-on-surface-variant/60 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all"
          placeholder="Your name" />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-on-surface mb-1">Email</label>
        <input type="email" id="email" name="email" required
          class="w-full px-4 py-2.5 bg-surface-bg border border-outline-variant rounded-lg text-sm text-on-surface placeholder:text-on-surface-variant/60 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all"
          placeholder="you@example.com" />
      </div>
      <div>
        <label for="subject" class="block text-sm font-medium text-on-surface mb-1">Subject</label>
        <input type="text" id="subject" name="subject" required
          class="w-full px-4 py-2.5 bg-surface-bg border border-outline-variant rounded-lg text-sm text-on-surface placeholder:text-on-surface-variant/60 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all"
          placeholder="What's this about?" />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium text-on-surface mb-1">Message</label>
        <textarea id="message" name="message" rows="5" required
          class="w-full px-4 py-2.5 bg-surface-bg border border-outline-variant rounded-lg text-sm text-on-surface placeholder:text-on-surface-variant/60 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all resize-none"
          placeholder="Your message..."></textarea>
      </div>
      <button type="submit"
        class="w-full sm:w-auto px-6 py-3 bg-primary text-white rounded-xl font-semibold hover:opacity-90 transition-opacity">
        Send Message
      </button>
    </form>

    <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
      <div class="p-4">
        <h3 class="font-semibold text-on-surface mb-1">Email</h3>
        <p class="text-sm text-on-surface-variant">hello@ai-tools-101.com</p>
      </div>
      <div class="p-4">
        <h3 class="font-semibold text-on-surface mb-1">Follow Us</h3>
        <div class="flex justify-center gap-3 mt-2">
          <a href={socialUrl('x', 'contact_page')} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-gray-100 hover:bg-gray-200 transition-colors" aria-label="X (Twitter)">
            <svg class="w-4 h-4 text-on-surface-variant" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href={socialUrl('pinterest', 'contact_page')} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-gray-100 hover:bg-gray-200 transition-colors" aria-label="Pinterest">
            <svg class="w-4 h-4 text-on-surface-variant" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/></svg>
          </a>
        </div>
      </div>
      <div class="p-4">
        <h3 class="font-semibold text-on-surface mb-1">Location</h3>
        <p class="text-sm text-on-surface-variant">Remote — Worldwide</p>
      </div>
    </div>
  </section>
</Layout>
