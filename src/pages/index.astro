---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout title="Home" description="AI Tool Guide - Tutorials, guides, and best practices for the latest AI tools. Learn ChatGPT, Midjourney, Copilot, and more.">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="text-center mb-10 md:mb-12">
      <h1 class="text-3xl md:text-5xl font-extrabold text-gray-900 mb-3 tracking-tight">
        Master AI Tools
      </h1>
      <p class="text-base md:text-lg text-gray-500 max-w-2xl mx-auto leading-relaxed">
        Step-by-step tutorials and guides for the best AI tools. From ChatGPT to Midjourney, learn to work smarter with AI.
      </p>
    </div>

    <div class="flex flex-wrap justify-center gap-6">
      {posts.map((post) => (
        <div class="w-full md:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]">
          <PostCard post={post} />
        </div>
      ))}
    </div>

    {posts.length === 0 && (
      <p class="text-center text-gray-400 py-16">No articles yet. Check back soon!</p>
    )}
  </section>
</Layout>
