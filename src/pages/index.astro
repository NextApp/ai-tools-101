---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout title="Home" description="AI Tool Guide - Tutorials, guides, and best practices for the latest AI tools. Learn ChatGPT, Midjourney, Copilot, and more.">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-4">
        Master AI Tools
      </h1>
      <p class="text-lg md:text-xl text-gray-600 max-w-2xl mx-auto">
        Step-by-step tutorials and guides for the best AI tools. From ChatGPT to Midjourney, learn to work smarter with AI.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => <PostCard post={post} />)}
    </div>

    {posts.length === 0 && (
      <p class="text-center text-gray-500 py-12">No articles yet. Check back soon!</p>
    )}
  </section>
</Layout>
