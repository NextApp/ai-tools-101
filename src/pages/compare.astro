---
import Layout from '../layouts/Layout.astro';
import toolsData from '../data/tools.json';
import pageContent from '../data/page-content.json';

const { compare: pc } = pageContent as any;
const tools = toolsData as any[];

const popularComparisons = pc.popular_comparisons || [];
---

<Layout title={pc.seo_title.split(' — ')[0]} description={pc.seo_description}>
  <script is:inline>
    window.__TOOLS_DATA__ = {JSON.stringify(tools)};
    window.__PAGE_CONTENT__ = {JSON.stringify(pc)};
  </script>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-16">
    <div class="text-center mb-10">
      <h1 class="text-3xl md:text-4xl font-extrabold text-on-surface mb-4">{pc.hero_title}</h1>
      <p class="text-base md:text-lg text-on-surface-variant max-w-2xl mx-auto leading-relaxed">{pc.hero_subtitle}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10 max-w-2xl mx-auto">
      <div>
        <label for="tool1-select" class="block text-sm font-semibold text-on-surface mb-2">{pc.select_tool_1_label}</label>
        <select id="tool1-select" class="w-full px-4 py-3 rounded-xl border border-outline-variant/60 bg-surface text-on-surface text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition-all" onchange="updateComparison()">
          <option value="">{pc.select_tool_placeholder}</option>
          {tools.map((t: any) => (
            <option value={t.slug}>{t.name} ({t.category})</option>
          ))}
        </select>
      </div>
      <div>
        <label for="tool2-select" class="block text-sm font-semibold text-on-surface mb-2">{pc.select_tool_2_label}</label>
        <select id="tool2-select" class="w-full px-4 py-3 rounded-xl border border-outline-variant/60 bg-surface text-on-surface text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary/40 transition-all" onchange="updateComparison()">
          <option value="">{pc.select_tool_placeholder}</option>
          {tools.map((t: any) => (
            <option value={t.slug}>{t.name} ({t.category})</option>
          ))}
        </select>
      </div>
    </div>

    <div id="comparison-result"></div>

    {popularComparisons.length > 0 && (
      <div class="mt-16 pt-10 border-t border-outline-variant/30">
        <h2 class="text-xl font-bold text-on-surface mb-2">{pc.popular_comparisons_title}</h2>
        <p class="text-sm text-on-surface-variant mb-6">{pc.popular_comparisons_subtitle}</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {popularComparisons.map((comp: any) => {
            const a = tools.find((t: any) => t.slug === comp.tool1);
            const b = tools.find((t: any) => t.slug === comp.tool2);
            if (!a || !b) return null;
            return (
              <a href={`/compare?tool1=${comp.tool1}&tool2=${comp.tool2}`} class="flex items-center gap-3 p-4 bg-surface border border-outline-variant/40 rounded-xl hover:border-primary/30 hover:shadow-sm transition-all">
                <span class="text-sm font-semibold text-on-surface">{a.name}</span>
                <span class="text-xs text-on-surface-variant">vs</span>
                <span class="text-sm font-semibold text-on-surface">{b.name}</span>
              </a>
            );
          }).filter(Boolean)}
        </div>
      </div>
    )}
  </section>

  <script>
    const tools = window.__TOOLS_DATA__;
    const pc = window.__PAGE_CONTENT__;

    function pricingBadgeClass(pricing: string) {
      if (pricing === 'Free' || pricing === 'Freemium') return 'bg-green-100 text-green-800';
      if (pricing === 'Free Trial') return 'bg-blue-100 text-blue-800';
      return 'bg-amber-100 text-amber-800';
    }

    function pricingLabel(pricing: string) {
      if (pricing === 'Freemium') return 'Freemium';
      if (pricing === 'Free') return 'Free';
      if (pricing === 'Free Trial') return 'Free Trial';
      return 'Paid';
    }

    function getToolsFromURL() {
      const params = new URLSearchParams(window.location.search);
      const slug1 = params.get('tool1');
      const slug2 = params.get('tool2');
      return {
        tool1: slug1 ? tools.find((t: any) => t.slug === slug1) || null : null,
        tool2: slug2 ? tools.find((t: any) => t.slug === slug2) || null : null,
      };
    }

    function renderComparison() {
      const { tool1, tool2 } = getToolsFromURL();
      const sel1 = document.getElementById('tool1-select') as HTMLSelectElement;
      const sel2 = document.getElementById('tool2-select') as HTMLSelectElement;
      const container = document.getElementById('comparison-result')!;

      if (tool1) sel1.value = tool1.slug;
      if (tool2) sel2.value = tool2.slug;

      if (!tool1 || !tool2) {
        container.innerHTML = `
          <div class="text-center py-20">
            <p class="text-on-surface-variant text-lg mb-2">${pc.no_tools_selected_title}</p>
            <p class="text-on-surface-variant text-sm">${pc.no_tools_selected_description}</p>
          </div>
        `;
        return;
      }

      const h = pc.comparison_table_headers;

      const toolHeader = (t: any) => `
        <div class="p-4 text-center">
          <a href="/tools/${t.slug}" class="text-lg font-bold text-on-surface hover:text-primary transition-colors">
            ${t.name}
          </a>
          <div class="flex items-center justify-center gap-2 mt-1">
            <span class="text-xs text-on-surface-variant">${t.category}</span>
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full ${pricingBadgeClass(t.pricing)}">
              ${pricingLabel(t.pricing)}
            </span>
          </div>
        </div>
      `;

      const featuresList = (items: string[]) => items.map(f => `
        <li class="flex items-start gap-2 text-sm text-on-surface-variant">
          <svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span>${f}</span>
        </li>
      `).join('');

      const prosList = (items: string[]) => items.map(p => `
        <li class="flex items-start gap-2 text-sm text-green-700">
          <span class="text-green-500 font-bold shrink-0">+</span>
          <span>${p}</span>
        </li>
      `).join('');

      const consList = (items: string[]) => items.map(c => `
        <li class="flex items-start gap-2 text-sm text-red-700">
          <span class="text-red-500 font-bold shrink-0">&minus;</span>
          <span>${c}</span>
        </li>
      `).join('');

      container.innerHTML = `
        <div class="bg-surface border border-outline-variant/40 rounded-xl overflow-hidden">
          <div class="grid grid-cols-[120px_1fr_1fr] border-b border-outline-variant/30 bg-surface-bg">
            <div class="p-4"></div>
            ${toolHeader(tool1)}
            ${toolHeader(tool2)}
          </div>
          <div class="grid grid-cols-[120px_1fr_1fr] border-b border-outline-variant/20">
            <div class="p-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wide bg-surface-bg/50">${h.overview}</div>
            <div class="p-4 text-sm text-on-surface-variant leading-relaxed">${tool1.description_short}</div>
            <div class="p-4 text-sm text-on-surface-variant leading-relaxed">${tool2.description_short}</div>
          </div>
          <div class="grid grid-cols-[120px_1fr_1fr] border-b border-outline-variant/20">
            <div class="p-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wide bg-surface-bg/50">${h.pricing}</div>
            <div class="p-4 text-sm text-on-surface-variant">
              <span class="font-semibold text-on-surface">${pricingLabel(tool1.pricing)}</span>
              <br /><span class="text-xs">${tool1.pricing_detail}</span>
            </div>
            <div class="p-4 text-sm text-on-surface-variant">
              <span class="font-semibold text-on-surface">${pricingLabel(tool2.pricing)}</span>
              <br /><span class="text-xs">${tool2.pricing_detail}</span>
            </div>
          </div>
          <div class="grid grid-cols-[120px_1fr_1fr] border-b border-outline-variant/20">
            <div class="p-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wide bg-surface-bg/50">${h.rating}</div>
            <div class="p-4"><span class="text-sm font-semibold text-on-surface">${tool1.rating} / 5</span></div>
            <div class="p-4"><span class="text-sm font-semibold text-on-surface">${tool2.rating} / 5</span></div>
          </div>
          <div class="grid grid-cols-[120px_1fr_1fr] border-b border-outline-variant/20">
            <div class="p-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wide bg-surface-bg/50">${h.features}</div>
            <div class="p-4"><ul class="space-y-1.5">${featuresList(tool1.features || [])}</ul></div>
            <div class="p-4"><ul class="space-y-1.5">${featuresList(tool2.features || [])}</ul></div>
          </div>
          <div class="grid grid-cols-[120px_1fr_1fr] border-b border-outline-variant/20">
            <div class="p-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wide bg-surface-bg/50">${h.pros}</div>
            <div class="p-4"><ul class="space-y-1.5">${prosList(tool1.pros || [])}</ul></div>
            <div class="p-4"><ul class="space-y-1.5">${prosList(tool2.pros || [])}</ul></div>
          </div>
          <div class="grid grid-cols-[120px_1fr_1fr]">
            <div class="p-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wide bg-surface-bg/50">${h.cons}</div>
            <div class="p-4"><ul class="space-y-1.5">${consList(tool1.cons || [])}</ul></div>
            <div class="p-4"><ul class="space-y-1.5">${consList(tool2.cons || [])}</ul></div>
          </div>
        </div>
      `;
    }

    function updateComparison() {
      const t1 = (document.getElementById('tool1-select') as HTMLSelectElement).value;
      const t2 = (document.getElementById('tool2-select') as HTMLSelectElement).value;
      const params = new URLSearchParams();
      if (t1) params.set('tool1', t1);
      if (t2) params.set('tool2', t2);
      const qs = params.toString();
      const newUrl = qs ? `/compare?${qs}` : '/compare';
      history.pushState(null, '', newUrl);
      renderComparison();
    }

    renderComparison();
    window.addEventListener('popstate', renderComparison);
  </script>
</Layout>
