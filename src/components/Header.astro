---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/tools', label: 'Tools' },
  { href: '/prompts', label: 'Prompts' },
  { href: '/which-ai-tool', label: 'Which AI Tool?' },
  { href: '/tags', label: 'Topics' },
];
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 w-full z-50 glass-header border-b border-outline-variant/30">
  <div class="flex justify-between items-center px-4 sm:px-6 lg:px-8 py-3.5 max-w-6xl mx-auto">
    <div class="flex items-center gap-8">
      <a href="/" class="text-xl font-extrabold text-on-surface tracking-tight hover:text-primary transition-colors">
        AI Tool Guide
      </a>
      <nav class="hidden sm:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`px-3 py-1.5 text-sm font-medium transition-colors rounded-md ${
              currentPath === link.href
                ? 'text-primary bg-primary/10'
                : 'text-on-surface-variant hover:text-primary'
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    <details class="sm:hidden relative">
      <summary class="list-none p-2 rounded-lg hover:bg-white/50 cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-on-surface-variant" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </summary>
      <nav class="absolute right-0 top-full mt-1 w-48 bg-surface rounded-xl shadow-lg border border-outline-variant/30 py-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`block px-4 py-2.5 text-sm font-medium transition-colors ${
              currentPath === link.href
                ? 'bg-primary/10 text-primary'
                : 'text-on-surface-variant hover:bg-surface-bg hover:text-primary'
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>
    </details>
  </div>
</header>
