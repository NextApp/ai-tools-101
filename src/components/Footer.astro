---
import { socialUrl } from '../lib/social';
---

<footer class="w-full bg-surface border-t border-outline-variant/30">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 px-4 sm:px-6 lg:px-8 py-12 max-w-6xl mx-auto">
    <div class="sm:col-span-2 lg:col-span-1">
      <span class="text-lg font-bold text-on-surface block mb-4">AI Tool Guide</span>
      <p class="text-sm text-on-surface-variant leading-relaxed mb-6">
        Empowering creators, entrepreneurs, and developers to navigate the future of work with artificial intelligence.
      </p>
      <div class="flex items-center gap-4">
        <a href={socialUrl('x', 'footer_social')} target="_blank" rel="noopener noreferrer" class="text-on-surface-variant hover:text-primary transition-colors" title="Follow us on X">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href={socialUrl('pinterest', 'footer_social')} target="_blank" rel="noopener noreferrer" class="text-on-surface-variant hover:text-primary transition-colors" title="Follow us on Pinterest">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0a12 12 0 0 0-4.73 23.06c-.06-.56-.01-1.23.14-1.84l1.03-4.35s-.27-.52-.27-1.3c0-1.22.7-2.13 1.58-2.13.75 0 1.1.56 1.1 1.23 0 .75-.48 1.87-.72 2.9-.2.86.43 1.56 1.28 1.56 1.54 0 2.72-1.62 2.72-3.96 0-2.07-1.49-3.52-3.61-3.52-2.46 0-3.9 1.85-3.9 3.76 0 .74.28 1.54.64 1.97.07.08.08.16.06.25-.07.28-.22.87-.25.99-.04.16-.13.2-.3.12-1.11-.52-1.8-2.14-1.8-3.44 0-2.8 2.04-5.38 5.88-5.38 3.08 0 5.48 2.2 5.48 5.13 0 3.06-1.93 5.53-4.61 5.53-.9 0-1.75-.47-2.04-1.02l-.55 2.11c-.2.77-.74 1.74-1.1 2.33A12 12 0 1 0 12 0z"/></svg>
        </a>

      </div>
    </div>
    <div>
      <h4 class="font-bold text-on-surface mb-5 text-sm">Navigation</h4>
      <ul class="space-y-2.5">
        <li><a href="/" class="text-on-surface-variant hover:text-primary transition-colors text-sm font-medium">Home</a></li>
        <li><a href="/tools" class="text-on-surface-variant hover:text-primary transition-colors text-sm font-medium">AI Tools</a></li>
        <li><a href="/prompts" class="text-on-surface-variant hover:text-primary transition-colors text-sm font-medium">Prompts</a></li>
        <li><a href="/which-ai-tool" class="text-on-surface-variant hover:text-primary transition-colors text-sm font-medium">Which AI Tool?</a></li>
        <li><a href="/tags" class="text-on-surface-variant hover:text-primary transition-colors text-sm font-medium">Topics</a></li>
        <li><a href="/about" class="text-on-surface-variant hover:text-primary transition-colors text-sm font-medium">About</a></li>
        <li><a href="/privacy-policy" class="text-on-surface-variant hover:text-primary transition-colors text-sm font-medium">Privacy Policy</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-bold text-on-surface mb-5 text-sm">Topics</h4>
      <ul class="space-y-2.5">
        <li><a href="/tags/chatgpt" class="text-on-surface-variant hover:text-primary transition-colors text-sm font-medium">ChatGPT</a></li>
        <li><a href="/tags/midjourney" class="text-on-surface-variant hover:text-primary transition-colors text-sm font-medium">Midjourney</a></li>
        <li><a href="/tags/github-copilot" class="text-on-surface-variant hover:text-primary transition-colors text-sm font-medium">GitHub Copilot</a></li>
        <li><a href="/tags/prompt-engineering" class="text-on-surface-variant hover:text-primary transition-colors text-sm font-medium">Prompt Engineering</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-bold text-on-surface mb-5 text-sm">Follow Us</h4>
      <div class="flex gap-3">
        <a href={socialUrl('x', 'footer_social')} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-gray-100 hover:bg-gray-200 transition-colors" aria-label="Follow on X (Twitter)" title="X / Twitter">
          <svg class="w-4 h-4 text-on-surface-variant" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href={socialUrl('pinterest', 'footer_social')} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-gray-100 hover:bg-gray-200 transition-colors" aria-label="Follow on Pinterest" title="Pinterest">
          <svg class="w-4 h-4 text-on-surface-variant" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/></svg>
        </a>
      </div>
    </div>
  </div>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-5 border-t border-outline-variant/20 flex flex-col sm:flex-row justify-between items-center gap-3">
    <span class="text-xs text-on-surface-variant">&copy; {new Date().getFullYear()} AI Tool Guide. All rights reserved.</span>
    <div class="flex items-center gap-4">
      <a href="/sitemap-index.xml" class="text-xs text-on-surface-variant hover:text-primary transition-colors">Sitemap</a>
    </div>
  </div>
</footer>
