---
interface Tool {
  name: string;
  slug: string;
  category: string;
  description_short: string;
  pricing: string;
  pricing_detail?: string;
  rating: number;
  logo?: string;
}

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
const pricingLabel = tool.pricing === 'Freemium' ? 'Freemium' : tool.pricing === 'Free' ? 'Free' : tool.pricing === 'Free Trial' ? 'Free Trial' : 'Paid';
const pricingColor = tool.pricing === 'Free' || tool.pricing === 'Freemium'
  ? 'bg-green-100 text-green-800'
  : tool.pricing === 'Free Trial'
    ? 'bg-blue-100 text-blue-800'
    : 'bg-amber-100 text-amber-800';

const stars = Math.round(tool.rating);
---

<a href={`/tools/${tool.slug}`} class="group bg-surface border border-outline-variant/60 rounded-xl overflow-hidden hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 flex flex-col h-full">
  <div class="p-6 flex flex-col h-full">
    <div class="flex items-start justify-between mb-3">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-primary/10 to-primary/5 flex items-center justify-center text-primary font-bold text-sm shrink-0">
          {tool.name.charAt(0)}
        </div>
        <div>
          <h3 class="text-base font-bold text-on-surface group-hover:text-primary transition-colors leading-snug">
            {tool.name}
          </h3>
        </div>
      </div>
      <div class="flex items-center gap-0.5 shrink-0">
        {Array.from({ length: 5 }).map((_, i) => (
          <svg class={`w-3.5 h-3.5 ${i < stars ? 'text-amber-400' : 'text-gray-200'}`} fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
        <span class="text-xs font-medium text-on-surface-variant ml-1">{tool.rating}</span>
      </div>
    </div>

    <p class="text-sm text-on-surface-variant leading-relaxed mb-4 text-truncate-3 flex-1">
      {tool.description_short}
    </p>

    <div class="flex items-center justify-between mt-auto">
      <span class="text-xs font-medium text-on-surface-variant bg-surface-bg px-2.5 py-1 rounded-full">
        {tool.category.replace('AI ', '')}
      </span>
      <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${pricingColor}`}>
        {pricingLabel}
      </span>
    </div>
  </div>
</a>
