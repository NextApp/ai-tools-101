---
interface Props {
  tag: string;
  size?: 'sm' | 'md';
}

const { tag, size = 'sm' } = Astro.props;
const sizeClasses = size === 'md' ? 'px-3 py-1 text-xs' : 'px-2.5 py-0.5 text-[0.7rem]';
---

<a
  href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`}
  class={`inline-flex items-center whitespace-nowrap ${sizeClasses} bg-[#F5F3FF] text-[#7C3AED] rounded-full font-semibold uppercase tracking-wider hover:bg-[#EDE9FE] transition-colors`}
>
  {tag}
</a>
