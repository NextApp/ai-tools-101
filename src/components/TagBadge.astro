---
interface Props {
  tag: string;
  size?: 'sm' | 'md';
}

const { tag, size = 'sm' } = Astro.props;
const sizeClasses = size === 'md' ? 'px-3 py-1 text-sm' : 'px-2 py-0.5 text-xs';
---

<a
  href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`}
  class={`inline-block ${sizeClasses} bg-primary/10 text-primary rounded-full font-medium hover:bg-primary/20 transition-colors`}
>
  {tag}
</a>
