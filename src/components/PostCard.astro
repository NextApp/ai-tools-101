---
import type { CollectionEntry } from 'astro:content';
import TagBadge from './TagBadge.astro';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const slug = post.id.replace('.md', '');
---

<article class="bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md hover:border-primary/40 transition-all duration-200 group">
  <a href={`/blog/${slug}`} class="flex flex-col p-6 h-full">
    <div class="flex flex-wrap gap-1.5 min-h-[1.75rem] mb-3">
      {tags.map((tag: string) => <TagBadge tag={tag} />)}
    </div>
    <h2 class="text-lg font-bold text-gray-900 mb-2 leading-snug group-hover:text-primary transition-colors flex-1">
      {title}
    </h2>
    <p class="text-sm text-gray-500 mb-4 line-clamp-2 leading-relaxed">{description}</p>
    <time datetime={pubDate.toISOString()} class="text-xs text-gray-400 mt-auto">
      {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>
  </a>
</article>
