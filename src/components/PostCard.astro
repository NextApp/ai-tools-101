---
import type { CollectionEntry } from 'astro:content';
import TagBadge from './TagBadge.astro';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const slug = post.id.replace('.md', '');
---

<article class="group bg-surface border border-outline-variant/60 rounded-xl overflow-hidden hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 flex flex-col h-full">
  <a href={`/blog/${slug}`} class="flex flex-col p-6 h-full">
    <div class="flex flex-wrap gap-1.5 mb-4">
      {tags.map((tag: string) => <TagBadge tag={tag} />)}
    </div>
    <h2 class="text-lg font-bold text-on-surface mb-2 text-truncate-2 leading-snug group-hover:text-primary transition-colors">
      {title}
    </h2>
    <p class="text-sm text-on-surface-variant mb-5 text-truncate-2 leading-relaxed">{description}</p>
    <div class="mt-auto pt-4 border-t border-outline-variant/30 flex items-center justify-between text-xs font-medium text-on-surface-variant">
      <time datetime={pubDate.toISOString()}>
        {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
      </time>
    </div>
  </a>
</article>
